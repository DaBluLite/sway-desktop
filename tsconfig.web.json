{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/app/env.d.ts",
    "src/renderer/src/app/**/*",
    "src/renderer/src/app/**/*.tsx",
    "src/renderer/src/overlay/env.d.ts",
    "src/renderer/src/overlay/**/*",
    "src/renderer/src/overlay/**/*.tsx",
    "src/preload/*.d.ts",
    "src/types/*.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@renderer/*": [
        "./src/renderer/src/app/*"
      ]
    }
  }
}
